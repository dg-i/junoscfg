vxlan: "aggregate" aggregate | "bfd" bfd | "decapsulate-accept-inner-vlan" | "encapsulate-inner-vlan" | "flags" VALUE | "flags" flags | "ingress-node-replication" | "multicast-group" VALUE | "multicast-v6-group" VALUE | "no-inner-payload" | "ovsdb-managed" | "riot-loopback" | "rsvd1" VALUE | "rsvd1-except" VALUE | "rsvd2" VALUE | "rsvd2-except" VALUE | "static-remote-vtep-list" VALUE | "translation-vni" VALUE | "unreachable-vtep-aging-timer" VALUE | "vni" VALUE | "vni-except" VALUE

vxlan_gpe: "destination" destination | "destination-udp-port" VALUE | "source" source | "tunnel-endpoint" VALUE | "vni" VALUE

vxlan_routing: "interface-num" VALUE | "loopback-port" VALUE | "next-hop" VALUE | "overlay-ecmp"

vxlan_tunnel_end_point: VALUE ("mode" VALUE | "nexthop" VALUE | "source-interface" VALUE | "source-ip-address" VALUE | "status" VALUE)*

wan_queue: "priority" priority

warmstart_not_operational: "radius" radius

warmstart_recovery_error: "radius" radius

warmstart_uppper_not_restacked: "radius" radius

warning: "link-down" | "packet-count" VALUE | "percentage" VALUE | "syslog"

watchdog: "timeout" VALUE | VALUE

wavelength: VALUE ("switch" switch | "wss-express-in")*

web_authentication: "http" | "https" | "redirect-to-https"

web_management: "control" control | "failover" VALUE | "https" https | "management-url" VALUE | "session" session | "traceoptions" traceoptions | VALUE

web_proxy: "secure-proxy" secure_proxy | "traceoptions" traceoptions

weighted: "one-hop"

weighted_averaged: "instant-usage-weight-exponent" VALUE

west_interface: "control-channel" control_channel | "interface-none" | "ring-protection-link-end"

when: "chassis" VALUE | "member" VALUE | "model" VALUE | "node" VALUE | "peers" VALUE | "routing-engine" VALUE | "time" time

wildcard_address: "wildcard-mask" VALUE | VALUE

wildcard_group_inet: "wildcard-source" wildcard_source

wildcard_group_inet6: "wildcard-source" wildcard_source

wildcard_source: "ingress-replication" ingress_replication | "inter-region-segmented" inter_region_segmented | "ldp-p2mp" | "next-hop" VALUE | "pim-ssm" pim_ssm | "rsvp-te" rsvp_te | "threshold-rate" VALUE

window_scale: "match" VALUE | "value" VALUE

window_size: "match" VALUE | "value" VALUE

withdraw_priority: "expedited" | "priority" VALUE

within: "events" VALUE | "not" not | "trigger" trigger | "within-value" VALUE | "within-variable" VALUE

wred: "config"

xauth: "access-profile" VALUE | "ip-address" VALUE

xauth_attributes: "primary-dns" VALUE | "primary-dns-ipv6" VALUE | "primary-wins" VALUE | "secondary-dns" VALUE | "secondary-dns-ipv6" VALUE | "secondary-wins" VALUE

xe: "port" | "port-range"

xle: "port" | "port-range"

xnm_clear_text: "connection-limit" VALUE | "rate-limit" VALUE

xnm_ssl: "connection-limit" VALUE | "local-certificate" VALUE | "no-ssl-renegotiation" | "rate-limit" VALUE | "ssl-renegotiation"

xor: "en-ip-over-mpls" | "mac-addresses" | "no-L3-L4-headers" | "no-L4-ports" | "no-destination-mac-address" | "no-ip6-flow-label" | "no-ipv4-destination-address" | "no-ipv4-source-address" | "no-ipv6-destination-address" | "no-ipv6-source-address" | "no-l4-destination-port" | "no-l4-source-port" | "no-mpls-hash" | "no-mpls-label0" | "no-mpls-label1" | "no-source-mac-address"

yang_module_capabilities: "advertise-custom-yang-modules" | "advertise-native-yang-modules" | "advertise-standard-yang-modules"

yang_modules: "device-specific" | "emit-extensions"

zero_suppression: "no-zero-suppression"

// Terminals
SET: "set"
DEACTIVATE: "deactivate"
VALUE: /\S+/
QUOTED: /"[^"]*"/
QUOTED_OR_VALUE: QUOTED | VALUE

// Whitespace handling
%import common.WS
%ignore WS

